if __name__ == '__main__':
    students = []
    for _ in range(int(input())):
        name = input()
        score = float(input())
        students.append([name, score])
    
    # 1. Get unique sorted scores to find the second lowest
    unique_scores = sorted(list(set([s[1] for s in students])))
    second_lowest = unique_scores[1]
    
    # 2. Find students with the second lowest score
    result = [s[0] for s in students if s[1] == second_lowest]
    
    # 3. Sort alphabetically and print
    for name in sorted(result):
        print(name)
