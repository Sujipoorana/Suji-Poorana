if __name__ == '__main__':
    # Reading input from separate lines
    x = int(input())
    y = int(input())
    z = int(input())
    n = int(input())
    
    # List comprehension to generate coordinates and filter sum
    result = [[i, j, k] for i in range(x + 1) for j in range(y + 1) for k in range(z + 1) if (i + j + k) != n]
    
    # Printing the result
    print(result)
