def print_formatted(number):
    # Calculate width based on the binary string of the maximum number
    width = len(bin(number)[2:])
    
    for i in range(1, number + 1):
        # Format decimal
        dec = str(i)
        # Format octal (remove '0o' prefix)
        octa = oct(i)[2:]
        # Format hexadecimal (remove '0x', capitalize)
        hexac = hex(i)[2:].upper()
        # Format binary (remove '0b')
        binary = bin(i)[2:]
        
        # Print padded values
        print(f"{dec.rjust(width)} {octa.rjust(width)} {hexac.rjust(width)} {binary.rjust(width)}")

